{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "linden",
  "name": "Dudji's Docs",
  "colors": {
    "primary": "#d5363e",
    "light": "#e05560",
    "dark": "#b02a32"
  },
  "appearance": {
    "default": "dark",
    "decorations": {
      "background": "grid"
    }
  },
  "background": {
    "decoration": "windows",
    "color": {
      "dark": "#060606"
    }
  },
  "styling": {
    "codeblocks": {
      "theme": {
        "dark": "tokyo-night",
        "light": "github-light"
      }
    }
  },
  "favicon": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "custom": {
    "css": "/custom.css"
  },
  "seo": {
    "indexHiddenPages": false
  },
  "fonts": {
    "body": { "family": "JetBrains Mono" },
    "heading": { "family": "JetBrains Mono" }
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Home",
      "href": "https://Dudji.com"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Overview",
        "groups": [
          {
            "group": "Overview",
            "pages": ["index"]
          }
        ]
      },
      {
        "tab": "Machines",
        "url": "writeups/machines/index",
        "groups": [
          {
            "group": "Overview",
            "pages": ["writeups/machines/index"]
          },
          {
            "group": "HackTheBox",
            "root": "writeups/machines/HackTheBox/index",
            "pages": [
              {
                "group": "Season 10",
                "root": "writeups/machines/HackTheBox/Season-10/index",
                "pages": [
                  {
                    "group": "Interpreter",
                    "root": "writeups/machines/HackTheBox/Season-10/interpreter",
                    "pages": [
                      "writeups/machines/HackTheBox/Season-10/interpreter/enumeration",
                      "writeups/machines/HackTheBox/Season-10/interpreter/foothold",
                      "writeups/machines/HackTheBox/Season-10/interpreter/lateral-movement",
                      "writeups/machines/HackTheBox/Season-10/interpreter/privilege-escalation"
                    ]
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "tab": "Challenges",
        "url": "writeups/Challenges/index",
        "groups": [
          {
            "group": "Challenges",
            "root": "writeups/Challenges/index",
            "pages": []
          }
        ]
      },
      {
        "tab": "CTFs",
        "url": "writeups/CTFs/index",
        "groups": [
          {
            "group": "CTFs",
            "root": "writeups/CTFs/index",
            "pages": []
          }
        ]
      }
    ],
    "global": {
      "anchors": []
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "https://dudji.com"
  },
  "footer": {
    "links": [
      {
        "header": "Dudji",
        "items": [
          { "label": "Home", "href": "https://dudji.com" },
          { "label": "Contact", "href": "https://dudji.com/contact" },
          { "label": "Hackbook", "href": "https://Hackbook.Dudji.com" },
          { "label": "Books", "href": "https://Books.Dudji.com" }
        ]
      },
      {
        "header": "Machines",
        "items": [
          {
            "label": "HackTheBox",
            "href": "/writeups/machines/HackTheBox/index"
          }
        ]
      },
      {
        "header": "Challenges",
        "items": [{ "label": "Coming soon", "href": "/writeups/Challenges" }]
      },
      {
        "header": "CTFs",
        "items": [{ "label": "Coming soon", "href": "/writeups/CTFs" }]
      }
    ],
    "socials": {
      "x": "https://x.com/dudji",
      "linkedin": "https://linkedin.com/in/dudji",
      "instagram": "https://instagram.com/dudji",
      "github": "https://github.com/0xDudji"
    }
  }
}
